#!/usr/bin/env bash
# load-secrets.sh — fetch prod secrets from 1Password and make them
# available to subsequent `make env=prod ...` calls.
#
# This is a TEMPLATE. To use in a project:
#   1. Copy to the project's scripts/ as load-secrets.sh
#   2. Replace the OP_VAULT, OP_ITEM, and SECRETS list below with project values
#   3. Replace the cache directory ${HOME}/.cache/<project>/ with your project name
#   4. Add the corresponding `-include $(HOME)/.cache/<project>/secrets.env` to your Makefile
#   5. Add a `load-secrets:` target that wraps this script
#
# Three supported invocation modes — all populate the same cache file
# at $HOME/.cache/<project>/secrets.env (mode 0600), which the Makefile -includes.
# Once the cache is populated, plain `make env=prod ...` works in any shell
# (no source / no inline prefix) until the cache is removed.
#
#   1. Run once (preferred, no shell juju):
#        make load-secrets        # writes the cache; nothing more to do
#
#   2. Source directly (also exports into current shell):
#        source scripts/load-secrets.sh
#
#   3. Eval via make (when wrapping in tooling):
#        source <(make -s load-secrets)
#
# Modes 2 and 3 still export into the current shell as before — useful when
# scripts or one-off shell snippets need the keys without going through make.
# Mode 1 covers the dominant case (running make targets) without polluting
# the parent shell.
#
# Prerequisites: `op` CLI installed and signed in (`op signin`).

set -euo pipefail

# === PROJECT CONFIG: replace these per-project ===
PROJECT="<project-name>"                          # e.g. "myapp"
OP_VAULT="<1password-vault>"                      # e.g. "Development"
OP_ITEM="<1password-item-name>"                   # e.g. "MyApp - Prod"
# Each line: VAR_NAME|op_field_name. Add as many as needed.
SECRETS=(
  "INTERNAL_API_KEY|prod_internal_api_key"
  "CURATOR_API_KEY|prod_curator_agent_key"
  "BASIC_AUTH_USERNAME|prod_basic_auth_username"
  "BASIC_AUTH_PASSWORD|prod_basic_auth_password"
)
# === end project config ===

# Detect: is this being sourced or executed?
_LS_SOURCED=0
if [ "${BASH_SOURCE[0]:-}" != "${0}" ]; then
  _LS_SOURCED=1
fi

# Pull each secret. Fail loud on empty — silent fallback to '' would let
# downstream commands hit prod with an empty key and produce confusing
# 401/403 errors.
declare -A SECRET_VALUES
for spec in "${SECRETS[@]}"; do
  var_name="${spec%%|*}"
  field_name="${spec##*|}"
  value=$(op read "op://${OP_VAULT}/${OP_ITEM}/${field_name}")
  if [ -z "$value" ]; then
    echo "ERROR: 1Password field '${field_name}' for ${var_name} returned empty — check '${OP_ITEM}' in the ${OP_VAULT} vault" >&2
    return 1 2>/dev/null || exit 1
  fi
  SECRET_VALUES[$var_name]="$value"
done

# Write the Make-includable cache file atomically.
_LS_CACHE_DIR="${HOME}/.cache/${PROJECT}"
_LS_CACHE_FILE="${_LS_CACHE_DIR}/secrets.env"
mkdir -p "$_LS_CACHE_DIR"
_LS_TMP="$(mktemp "${_LS_CACHE_DIR}/.secrets.XXXXXX")"
chmod 600 "$_LS_TMP"
{
  echo "# ${PROJECT} prod secrets — populated by scripts/load-secrets.sh"
  echo "# Generated: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
  echo "# Refresh with: make load-secrets   |   Clear with: rm ${_LS_CACHE_FILE}"
  for var_name in "${!SECRET_VALUES[@]}"; do
    printf '%s := %s\n' "$var_name" "${SECRET_VALUES[$var_name]}"
  done
} > "$_LS_TMP"
mv "$_LS_TMP" "$_LS_CACHE_FILE"

if [ "$_LS_SOURCED" = "1" ]; then
  for var_name in "${!SECRET_VALUES[@]}"; do
    export "$var_name=${SECRET_VALUES[$var_name]}"
  done
  {
    echo "==> ${PROJECT} prod secrets loaded"
    for var_name in "${!SECRET_VALUES[@]}"; do
      echo "    ${var_name}      ✓"
    done
    echo "    Cache written:        $_LS_CACHE_FILE"
  } >&2
else
  for var_name in "${!SECRET_VALUES[@]}"; do
    printf 'export %s=%q\n' "$var_name" "${SECRET_VALUES[$var_name]}"
  done
  {
    echo "==> ${PROJECT} prod secrets loaded"
    echo "    Cache:  $_LS_CACHE_FILE  (auto-included by Makefile for env=prod targets)"
  } >&2
fi
